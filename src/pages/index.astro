---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import HomeCard from '../components/HomeCard.astro';

const allWork = await getCollection('work');
const sorted = [...allWork].sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const featured = sorted.find((w) => w.data.featured) ?? sorted[0];
const others = sorted.filter((w) => w.id !== featured.id).slice(0, 6);

const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

const ctaByType: Record<string, string> = {
  podcast: 'Listen to the series',
  documentary: 'Watch the film',
  photography: 'View the series',
  reportage: 'Read the story',
  commissioned: 'View the project',
};

const featuredPrimary = featured.data.types[0];
const featuredCta = ctaByType[featuredPrimary];
const featuredChip = featured.data.client
  ? `${cap(featuredPrimary)} · ${featured.data.client}`
  : cap(featuredPrimary);

const fmtDate = (d: Date) => {
  const dd = String(d.getUTCDate()).padStart(2, '0');
  const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
  const yy = String(d.getUTCFullYear()).slice(2);
  return `${dd}.${mm}.${yy}`;
};

const featuredMeta = featured.data.dateline
  ? `${featured.data.dateline} · ${featured.data.year}`
  : String(featured.data.year);

const minYear = Math.min(...allWork.map((w) => w.data.year));
const maxYear = Math.max(...allWork.map((w) => w.data.year));
const yearRange = `${minYear}—${maxYear}`;
---
<BaseLayout title="ontheground — Rotterdam, est. 2020">
  <SiteNav />

  {/* Hero */}
  <section style="padding: 112px 64px 88px;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div class="dateline" style="margin-bottom: 40px;">
        ontheground · journalism production house · est. Rotterdam 2020
      </div>
      <h1
        class="sans"
        style="font-size: 128px; line-height: 0.94; letter-spacing: -0.045em; font-weight: 400; max-width: 1200px;"
      >
        We believe<br />
        in telling
        <em style="font-style: italic; font-family: var(--font-serif); font-weight: 400;">
          true stories<span style="color: var(--accent);">.</span>
        </em>
      </h1>
    </div>
  </section>

  {/* Featured story */}
  <section style="padding: 64px 64px 96px;">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 40px;">
        <span class="label label--wide">Featured · This month</span>
        <span class="dateline">Published {fmtDate(featured.data.publishedAt)}</span>
      </div>
      <div style="display: grid; grid-template-columns: 1.6fr 1fr; gap: 72px; align-items: center;">
        <a href={`/work/${featured.data.slug}`} style="display: block; color: inherit;">
          <div class="photo" style="aspect-ratio: 8 / 5;">
            <img src={featured.data.hero} alt={featured.data.title} draggable="false" />
            <span class="chip" style="top: 20px; left: 20px;">{featuredChip}</span>
          </div>
        </a>
        <div>
          <span class="dateline">{featuredMeta}</span>
          <h2
            class="sans"
            style="font-size: 68px; line-height: 0.98; letter-spacing: -0.035em; font-weight: 500; margin-top: 24px;"
          >
            {featured.data.title}<span style="color: var(--accent);">.</span>
          </h2>
          <p
            class="serif"
            style="font-size: 19px; line-height: 1.5; color: var(--ink-2); margin-top: 28px; max-width: 460px;"
          >
            {featured.data.excerpt}
          </p>
          <div style="margin-top: 36px;">
            <a class="btn btn--primary btn--lg" href={`/work/${featured.data.slug}`}>
              {featuredCta}
              <svg width="20" height="14" viewBox="0 0 20 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <line x1="0" y1="7" x2="18" y2="7" stroke-linecap="round" />
                <polyline points="13,2 19,7 13,12" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Selected work */}
  <section style="padding: 80px 64px; border-top: 1px solid var(--rule);">
    <div style="max-width: 1280px; margin: 0 auto;">
      <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 56px;">
        <div>
          <span class="label label--wide">{yearRange}</span>
          <h3
            class="sans"
            style="font-size: 44px; font-weight: 500; letter-spacing: -0.025em; margin-top: 14px;"
          >
            Selected work<span style="color: var(--accent);">.</span>
          </h3>
        </div>
        <a class="navlink" href="/work" style="display: flex; align-items: center; gap: 10px;">
          Full archive
          <svg width="20" height="14" viewBox="0 0 20 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <line x1="0" y1="7" x2="18" y2="7" stroke-linecap="round" />
            <polyline points="13,2 19,7 13,12" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; row-gap: 72px;">
        {others.map((w) => (
          <HomeCard
            title={w.data.title}
            types={w.data.types}
            year={w.data.year}
            hero={w.data.hero}
            excerpt={w.data.excerpt}
            slug={w.data.slug}
            client={w.data.client}
            dateline={w.data.dateline}
          />
        ))}
      </div>
    </div>
  </section>

  {/* Dispatch */}
  <section style="padding: 96px 64px; background: var(--ink); color: var(--paper); border-top: 1px solid var(--rule);">
    <div style="max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 96px; align-items: center;">
      <div>
        <span class="dateline" style="color: var(--accent);">Newsletter</span>
        <h3
          class="sans"
          style="font-size: 56px; line-height: 1.02; letter-spacing: -0.03em; font-weight: 500; margin-top: 20px;"
        >
          One letter<br />a month<span style="color: var(--accent);">.</span>{' '}
          <em style="font-style: italic; font-family: var(--font-serif); font-weight: 400; color: var(--paper-3);">
            Never breaking.<br />Always grounded.
          </em>
        </h3>
      </div>
      <div>
        <p
          class="serif"
          style="font-size: 18px; line-height: 1.55; color: #CFC6B3; max-width: 460px; margin-bottom: 28px;"
        >
          Where we are, what we&rsquo;re hearing, a photograph we can&rsquo;t stop looking at, a sentence we
          overheard at a kitchen table. Sent when there&rsquo;s something worth sending.
        </p>
        <form
          onsubmit="event.preventDefault();"
          style="display: grid; grid-template-columns: 1fr auto; border: 1px solid #3A342C; background: rgba(244,239,230,0.04);"
        >
          <input
            type="email"
            name="email"
            placeholder="your@email"
            class="serif"
            style="border: none; background: transparent; padding: 18px 20px; font-size: 16px; color: var(--paper); outline: none;"
          />
          <button type="submit" class="btn btn--accent" style="border-radius: 0; border: none;">
            Subscribe
          </button>
        </form>
        <div class="dateline" style="margin-top: 18px; color: #8E8674;">
          1,247 subscribers · No tracking · Unsubscribe in 2 clicks
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
