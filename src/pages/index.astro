---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import Dot from '../components/Dot.astro';
import { currentLocation } from '../data/status';

const allWork = await getCollection('work');

const tiles = allWork
  .filter((w) => w.data.homepage)
  .sort((a, b) => {
    const ao = a.data.homepageOrder ?? Number.POSITIVE_INFINITY;
    const bo = b.data.homepageOrder ?? Number.POSITIVE_INFINITY;
    if (ao !== bo) return ao - bo;
    return b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
  });
---
<BaseLayout title="ontheground — Rotterdam, est. 2020">
  <SiteNav />

  {/* Hero */}
  <section class="hp-hero">
    <p class="dateline hp-hero__dateline">ontheground · Independent studio for journalism · Est. Rotterdam 2020</p>
    <h1 class="hp-hero__h">
      We believe in<br />
      telling <em class="hp-hero__em">true stories<Dot /></em>
    </h1>
  </section>

  {/* Asymmetric image grid */}
  <section class="hp-grid-section">
    <div class="hp-grid">
      {tiles.map((w) => (
        <a
          href={`/work/${w.data.slug}`}
          class:list={['hp-tile', `hp-tile--${w.data.homepageFormat}`]}
          style={`aspect-ratio: ${w.data.imageAspect};`}
          aria-label={w.data.title}
        >
          <img
            src={w.data.homepageImage ?? w.data.hero}
            alt={w.data.title}
            draggable="false"
          />
          <div class="hp-tile__overlay">
            <span class="hp-tile__title">{w.data.title}<Dot /></span>
          </div>
        </a>
      ))}
    </div>
  </section>

  {/* CTA */}
  <section class="hp-cta">
    <h2 class="hp-cta__line">
      Let&rsquo;s grab a coffee. I&rsquo;m in Rotterdam,{' '}
      <em class="hp-cta__em">or elsewhere<Dot /></em>
    </h2>
    <div class="hp-cta__meta">
      <a class="hp-cta__mail" href="mailto:marcel@alwaysontheground.com">
        marcel@alwaysontheground.com
      </a>
      {currentLocation && (
        <Fragment>
          <span class="hp-cta__sep" aria-hidden="true">·</span>
          <span class="hp-cta__loc">Currently in {currentLocation}<Dot /></span>
        </Fragment>
      )}
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hp-hero {
    padding: 112px 64px 88px;
    max-width: 1280px;
    margin: 0 auto;
  }
  .hp-hero__dateline {
    margin: 0 0 32px;
  }
  .hp-hero__h {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(48px, 7vw, 96px);
    line-height: 1.0;
    letter-spacing: -0.04em;
  }
  .hp-hero__em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
  }

  /* ── Grid ─────────────────────────────────────────────── */
  .hp-grid-section {
    padding: 0 64px 96px;
    max-width: 1280px;
    margin: 0 auto;
  }
  .hp-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-flow: dense;
    align-items: start;
    gap: 24px;
  }

  .hp-tile {
    position: relative;
    display: block;
    overflow: hidden;
    background: var(--paper-3);
    color: inherit;
    cursor: pointer;
  }
  .hp-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hp-tile--narrow { grid-column: span 1; }
  .hp-tile--wide   { grid-column: span 2; }

  .hp-tile__overlay {
    position: absolute;
    inset: auto 0 0 0;
    padding: 22px 22px 20px;
    background: linear-gradient(
      to top,
      rgba(26, 23, 20, 0.72) 0%,
      rgba(26, 23, 20, 0.32) 60%,
      rgba(26, 23, 20, 0) 100%
    );
    color: var(--paper);
    opacity: 0;
    transition: opacity 0.18s ease;
    pointer-events: none;
  }
  .hp-tile:hover .hp-tile__overlay,
  .hp-tile:focus-visible .hp-tile__overlay {
    opacity: 1;
  }
  .hp-tile__title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 22px;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  /* Mobile: 2-column grid */
  @media (max-width: 720px) {
    .hp-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .hp-grid-section { padding: 0 20px 64px; }
    .hp-hero { padding: 64px 20px 56px; }
  }

  /* ── CTA ──────────────────────────────────────────────── */
  .hp-cta {
    padding: 96px 64px;
    max-width: 1280px;
    margin: 0 auto;
    text-align: center;
    border-top: 1px solid var(--rule);
  }
  .hp-cta__line {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 auto;
  }
  .hp-cta__em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
  }
  .hp-cta__meta {
    margin-top: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  .hp-cta__mail,
  .hp-cta__loc {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .hp-cta__mail:hover { color: var(--accent); }
  .hp-cta__sep {
    font-family: var(--font-mono);
    color: var(--ink-4);
  }

  @media (max-width: 720px) {
    .hp-cta { padding: 64px 20px; }
  }

</style>
