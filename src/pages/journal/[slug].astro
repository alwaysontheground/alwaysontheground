---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { slug: 'placeholder' } }];
}

const { slug } = Astro.params;
---
<BaseLayout title={`${slug} — journal · ontheground`}>
  <main style="padding: 96px 48px; max-width: 1280px; margin: 0 auto;">
    <span class="label">Placeholder · journal post</span>
    <h1 class="ty-h1" style="margin-top: 16px;">
      {slug}<span style="color: var(--accent);">.</span>
    </h1>
    <p class="serif" style="margin-top: 24px; color: var(--ink-2); max-width: 60ch;">
      This is a placeholder for a single journal post. In step 6 it will be powered by the <code>journal</code> content collection (Markdown / MDX).
    </p>
    <p style="margin-top: 32px;">
      <a class="navlink" href="/journal">← Back to journal</a> &middot;
      <a class="navlink" href="/">Home</a>
    </p>
  </main>
</BaseLayout>
