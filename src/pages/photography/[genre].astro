---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import Footer from '../../components/Footer.astro';
import Dot from '../../components/Dot.astro';
import Lightbox from '../../components/Lightbox.astro';

type Genre = 'portrait' | 'documentary' | 'street' | 'commissioned';

const GENRES: Record<string, { genre: Genre; title: string; lead: string }> = {
  portraits: {
    genre: 'portrait',
    title: 'Portraits',
    lead: 'Faces met along the way. People photographed at home, at work, or at the side of the road.',
  },
  documentary: {
    genre: 'documentary',
    title: 'Documentary',
    lead: 'Frames from longer projects. Stories that take more than one visit to tell.',
  },
  street: {
    genre: 'street',
    title: 'Street',
    lead: 'Things noticed in passing. Mostly unposed, mostly fast.',
  },
  commissioned: {
    genre: 'commissioned',
    title: 'Commissioned',
    lead: 'Editorial and corporate assignments. Made on brief, kept on the record.',
  },
};

export async function getStaticPaths() {
  return [
    { params: { genre: 'portraits' } },
    { params: { genre: 'documentary' } },
    { params: { genre: 'street' } },
    { params: { genre: 'commissioned' } },
  ];
}

const { genre: slug } = Astro.params;
const meta = GENRES[slug as string];
if (!meta) {
  return Astro.redirect('/photography');
}

const FORMAT_PATTERN = ['wide', 'narrow', 'narrow', 'wide', 'narrow'];

const allPhotos = await getCollection('photos');
const photos = allPhotos
  .filter((p) => p.data.genre === meta.genre)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---
<BaseLayout title={`${meta.title} — Photography — ontheground`}>
  <SiteNav />

  <section class="pc-hero">
    <p class="pc-hero__crumb">
      <a href="/photography">Photography</a> <span aria-hidden="true">·</span> Collection
    </p>
    <h1 class="pc-hero__h">{meta.title}<Dot /></h1>
    <p class="pc-hero__lead">{meta.lead}</p>
  </section>

  <section class="pc-grid-section">
    {photos.length === 0 ? (
      <p class="pc-empty">Collection coming soon<Dot /></p>
    ) : (
      <div class="pc-grid" data-lightbox-group>
        {photos.map((p, i) => {
          const format = FORMAT_PATTERN[i % FORMAT_PATTERN.length];
          const cap = p.data.location
            ? `${p.data.location} · ${p.data.publishedAt.getFullYear()}`
            : String(p.data.publishedAt.getFullYear());
          return (
            <button
              type="button"
              class:list={['pc-tile', `pc-tile--${format}`]}
              style={`aspect-ratio: ${p.data.aspect};`}
              data-lightbox-src={p.data.image}
              data-lightbox-caption={cap}
              aria-label={`Open ${p.data.title} in viewer`}
            >
              <img
                src={p.data.image}
                alt={p.data.caption ?? p.data.title}
                draggable="false"
                data-photo-asset
              />
              {p.data.location && (
                <span class="pc-tile__cap">{p.data.location}</span>
              )}
            </button>
          );
        })}
      </div>
    )}
  </section>

  <Lightbox />

  <Footer />
</BaseLayout>

<style>
  .pc-hero {
    padding: 96px 64px 56px;
    max-width: 1280px;
    margin: 0 auto;
  }
  .pc-hero__crumb {
    font-family: var(--font-mono);
    font-size: var(--fs-xxs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 24px;
  }
  .pc-hero__crumb a {
    color: var(--ink-3);
    transition: color 0.18s ease;
  }
  .pc-hero__crumb a:hover {
    color: var(--accent);
  }
  .pc-hero__h {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(48px, 7vw, 96px);
    line-height: 1.0;
    letter-spacing: -0.04em;
  }
  .pc-hero__lead {
    margin-top: 32px;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.5;
    letter-spacing: -0.005em;
    color: var(--ink-2);
    max-width: 56ch;
  }

  .pc-grid-section {
    padding: 0 64px 112px;
    max-width: 1280px;
    margin: 0 auto;
  }
  .pc-empty {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 20px;
    color: var(--ink-3);
    padding: 48px 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    text-align: center;
  }
  .pc-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-flow: dense;
    align-items: start;
    gap: 24px;
  }
  .pc-tile {
    position: relative;
    margin: 0;
    padding: 0;
    border: 0;
    background: var(--paper-3);
    overflow: hidden;
    display: block;
    cursor: pointer;
    color: inherit;
    font: inherit;
    text-align: left;
  }
  .pc-tile:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  .pc-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    -webkit-user-drag: none;
    user-drag: none;
  }
  .pc-tile--narrow { grid-column: span 1; }
  .pc-tile--wide   { grid-column: span 2; }

  .pc-tile__cap {
    position: absolute;
    inset: auto 0 0 0;
    padding: 14px 16px;
    background: linear-gradient(
      to top,
      rgba(26, 23, 20, 0.72) 0%,
      rgba(26, 23, 20, 0) 100%
    );
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: var(--fs-xxs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 0.18s ease;
    pointer-events: none;
  }
  .pc-tile:hover .pc-tile__cap {
    opacity: 1;
  }

  @media (max-width: 720px) {
    .pc-hero { padding: 56px 20px 40px; }
    .pc-grid-section { padding: 0 20px 80px; }
    .pc-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }
</style>
