---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Dot from '../../components/Dot.astro';

export function getStaticPaths() {
  return [{ params: { slug: 'placeholder' } }];
}

const { slug } = Astro.params;
---
<BaseLayout title={`${slug} — field notes · ontheground`}>
  <main style="padding: 96px 48px; max-width: 1280px; margin: 0 auto;">
    <span class="label">Placeholder · field notes post</span>
    <h1 class="ty-h1" style="margin-top: 16px;">
      {slug}<Dot />
    </h1>
    <p class="serif" style="margin-top: 24px; color: var(--ink-2); max-width: 60ch;">
      This is a placeholder for a single field notes post. In step 6 it will be powered by the <code>fieldNotes</code> content collection (Markdown / MDX).
    </p>
    <p style="margin-top: 32px;">
      <a class="navlink" href="/field-notes">← Back to field notes</a> &middot;
      <a class="navlink" href="/">Home</a>
    </p>
  </main>
</BaseLayout>
