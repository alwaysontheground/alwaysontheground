---
import Wordmark from './Wordmark.astro';

const items = [
  { label: 'Work',        href: '/work' },
  { label: 'Field notes', href: '/field-notes' },
  { label: 'About',       href: '/about' },
  { label: 'Contact',     href: '/contact' },
];
---
<footer
  style="
    background: var(--paper-2);
    border-top: 1px solid var(--rule);
    padding: 40px 48px 28px;
  "
>
  <div
    style="
      max-width: 1280px;
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 20px 32px;
    "
  >
    <div
      class="serif"
      style="display: flex; flex-wrap: wrap; align-items: center; gap: 10px; color: var(--ink-2); font-size: 15px;"
    >
      <Wordmark size={20} href="/" />
      <span style="color: var(--ink-4);">·</span>
      <span>Marcel van der Steen</span>
      <span style="color: var(--ink-4);">·</span>
      <span>Rotterdam</span>
      <span style="color: var(--ink-4);">·</span>
      <a class="navlink" href="mailto:marcel@alwaysontheground.com">marcel@alwaysontheground.com</a>
    </div>
    <nav style="display: flex; flex-wrap: wrap; gap: 24px;">
      {items.map((x) => <a class="navlink" href={x.href}>{x.label}</a>)}
    </nav>
  </div>
  <div
    class="dateline"
    style="max-width: 1280px; margin: 24px auto 0; color: var(--ink-3);"
  >
    © ontheground 2020–2026.
  </div>
</footer>
