---
import Wordmark from './Wordmark.astro';

interface Props {
  lang?: 'EN' | 'NL';
}
const { lang = 'EN' } = Astro.props;

const items = [
  { label: 'Reportage',    href: '/reportage' },
  { label: 'Podcast',      href: '/podcast' },
  { label: 'Documentary',  href: '/documentary' },
  { label: 'Photography',  href: '/photography' },
  { label: 'Commissioned', href: '/commissioned' },
  { label: 'Journal',      href: '/journal' },
  { label: 'About',        href: '/about' },
  { label: 'Contact',      href: '/contact' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---
<div
  style="
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 48px;
    padding: 22px 48px;
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
  "
>
  <Wordmark size={28} href="/" />
  <nav style="display: flex; gap: 28px; justify-content: center;">
    {items.map((it) => (
      <a
        href={it.href}
        class:list={['navlink', isActive(it.href) && 'navlink--active']}
      >
        {it.label}
      </a>
    ))}
  </nav>
  <div style="display: flex; align-items: center; gap: 20px;">
    <div class="dateline" style="color: var(--ink-3);">
      <span style={`color: ${lang === 'EN' ? 'var(--fg)' : 'var(--ink-4)'};`}>EN</span>
      <span style="margin: 0 6px; color: var(--ink-4);">/</span>
      <span style={`color: ${lang === 'NL' ? 'var(--fg)' : 'var(--ink-4)'};`}>NL</span>
    </div>
    <button class="btn btn--ghost btn--sm" type="button" aria-label="Search" style="border-width: 1px;">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4">
        <circle cx="6" cy="6" r="4.5" />
        <line x1="9.5" y1="9.5" x2="12.5" y2="12.5" stroke-linecap="round" />
      </svg>
      Search
    </button>
  </div>
</div>
